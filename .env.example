# Digicracy web — environment variables

# Public site URL (used for canonical URLs, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://digicracy.org

# Plausible analytics domain (privacy-friendly — NOT Google Analytics)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=digicracy.org
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Newsletter (Buttondown / Ghost / Mailchimp — pick one before launch)
# NEWSLETTER_PROVIDER=buttondown
# NEWSLETTER_API_KEY=
